# ============================================
# Hearth — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values

# --- Database ---
POSTGRES_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql://hearth:changeme_strong_password_here@localhost:5432/hearth

# --- Auth ---
JWT_SECRET=changeme_generate_a_random_64_char_string

# --- Server ---
PORT=3001
CLIENT_URL=http://localhost:5173

# --- LiveKit ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_changeme_in_production
LIVEKIT_URL=ws://localhost:7880

# --- Initial Admin User (used by seed script) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@hearth.local
ADMIN_PASSWORD=changeme_admin_password

# --- Cloudflare R2 (Phase 2 — not needed yet) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=hearth-uploads
# R2_PUBLIC_URL=
